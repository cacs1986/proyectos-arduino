void mostrarCara(const unsigned char* cara) {
  display.clearDisplay();
  display.drawBitmap(0, 0, cara, 128, 64, SSD1306_WHITE);
  display.display();
}

void setup() {
  Wire.begin();

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    while (true); // si falla, queda acá
  }

  // Mostrar todas las caras una por una
  mostrarCara(epd_bitmap_caraNormal);
  delay(2000);

  mostrarCara(epd_bitmap_caraFeliz);
  delay(2000);

  mostrarCara(epd_bitmap_caraDormida);
  delay(2000);

  mostrarCara(epd_bitmap_caraEnojada);
  delay(2000);

  mostrarCara(epd_bitmap_caraAburrida);
  delay(2000);
}

